# ===========================================
# Facebook Auto Post Creator - Configuration
# ===========================================

# Server
PORT=3001
NODE_ENV=production

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=fb_post_creator
DB_USER=root
DB_PASSWORD=your_db_password_here

# Admin Password (mật khẩu đăng nhập)
ADMIN_PASSWORD=admin123

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here

# Google AI (Gemini)
GOOGLE_AI_API_KEY=your_google_ai_api_key_here

# Facebook
FB_PAGE_ID=your_page_id_here
FB_ACCESS_TOKEN=your_page_access_token_here
FB_API_VERSION=v25.0
FB_APP_ID=your_fb_app_id_here
FB_APP_SECRET=your_fb_app_secret_here

# App
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
